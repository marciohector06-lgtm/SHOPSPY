{
  "name": "shopspy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "worker": "turbo run worker",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit packages/*/tests",
    "test:integration": "vitest run tests/integration",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run generate --workspace=@shopspy/database",
    "db:migrate": "npm run migrate:dev --workspace=@shopspy/database",
    "db:studio": "npm run studio --workspace=@shopspy/database"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.16.0",
  "allowScripts": {
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true,
    "prisma@5.22.0": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "puppeteer@25.3.0": true,
    "@google/genai@2.13.0": true,
    "protobufjs@7.6.5": true,
    "msgpackr-extract@3.0.4": true
  }
}
