# ─── Banco de dados (Supabase Postgres) ──────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ─── Cache (Upstash Redis) ────────────────────────────────────────────────────
REDIS_URL="rediss://default:password@host:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── IA (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Assina o access token (JOSE/HS256, 1h). O refresh token NÃO é JWT — é um
# valor opaco gerado com crypto.randomBytes e guardado na tabela Session
# (7 dias), por isso não existe um "JWT_REFRESH_SECRET" separado.
JWT_ACCESS_SECRET=""

# Console do Google Cloud > APIs & Services > Credentials > OAuth Client ID
# (tipo "Web application"). GOOGLE_REDIRECT_URI deve ser cadastrada lá
# exatamente igual (inclui o path /auth/google/callback).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/auth/google/callback"

# POST /auth/login e /auth/register (email+senha) — modo de acesso temporário
# pra testar sem depender do OAuth do Google. Fica ligado sozinho fora de
# produção (NODE_ENV != production). Em produção só liga de propósito, porque
# /register cria a conta já em plan: PRO, sem passar pelo checkout.
ENABLE_PASSWORD_AUTH="false"

# Pra onde a API redireciona depois do login (com o token na query) e pra
# onde o CORS libera credentials.
FRONTEND_URL="http://localhost:3000"

# Domínio do cookie de sessão (shopspy_access/shopspy_refresh), setado pelo
# frontend. Deixe vazio em dev (host-only funciona em qualquer porta do
# localhost). Em produção, use o domínio pai compartilhado entre o front
# (Vercel) e a API (Railway), ex.: ".shopspy.com.br" com subdomínios
# app.shopspy.com.br / api.shopspy.com.br — domínios totalmente diferentes
# (tipo vercel.app vs railway.app) NÃO conseguem compartilhar cookie.
COOKIE_DOMAIN=""

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
CORS_ALLOWED_ORIGINS="http://localhost:3000"
# Token exigido no header X-Internal-Token para POST /internal/jobs/:source/trigger
INTERNAL_TOKEN=""

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── Câmbio (para conversão USD -> BRL nos scrapers globais) ─────────────────
EXCHANGE_RATE_API_URL="https://api.exchangerate-api.com/v4/latest/USD"

# ─── AliExpress Affiliate API (Open Platform / TOP API) ──────────────────────
# Cadastro em portals.aliexpress.com/affiportals — necessário porque o
# robots.txt do AliExpress bloqueia os endpoints públicos de busca/wholesale.
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""

# ─── Alertas por e-mail (Resend) ──────────────────────────────────────────────
# resend.com/api-keys — free tier: 3.000 emails/mês. Sem essa chave, o
# worker de alertas loga o erro e segue (nunca trava o ciclo por causa
# disso), mas nenhum e-mail é enviado de fato.
RESEND_API_KEY=""
# Precisa ser um domínio verificado no Resend (resend.com/domains).
RESEND_FROM_EMAIL="ShopSpy <alertas@shopspy.com.br>"
